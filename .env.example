## Finnhub (server-side only)
FINNHUB_API_KEY=your_finnhub_api_key_here

## Optional — separate Finnhub key handed to signed-in browsers for the live
## WebSocket (falls back to FINNHUB_API_KEY). Using a second free-tier key
## means a leaked browser key can't exhaust the server-side REST quota.
FINNHUB_WS_API_KEY=

## Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

## Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

## Optional — Anthropic (AI Analyst)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

## Optional — Upstash Redis (caching + API rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

## Optional — server-side push alerts (Web Push)
## Generate a key pair with: npx web-push generate-vapid-keys
## CRON_SECRET must match the ALERT_CRON_SECRET GitHub repo secret used by
## .github/workflows/alert-cron.yml
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
CRON_SECRET=
